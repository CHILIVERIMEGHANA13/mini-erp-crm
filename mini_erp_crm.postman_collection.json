{
  "info": {
    "name": "Mini ERP + CRM Operations Portal API Collection",
    "description": "Complete REST API collection for placement drive evaluation. Covers Auth, Customers CRM, Product Inventory, and Sales Challans workflow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@minierp.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Customer CRM",
      "item": [
        {
          "name": "Get All Customers (With Search & Filters)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/customers?search=Apex&status=Active",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["customers"],
              "query": [
                { "key": "search", "value": "Apex" },
                { "key": "status", "value": "Active" }
              ]
            }
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rohan Verma\",\n  \"mobile\": \"+91 9811223344\",\n  \"email\": \"rohan@vermaelectronics.com\",\n  \"businessName\": \"Verma Electronics & Components\",\n  \"gstNumber\": \"27AAAAA0000A1Z5\",\n  \"type\": \"Wholesale\",\n  \"address\": \"Gala 12, Industrial Estate, Pune\",\n  \"status\": \"Active\",\n  \"followUpDate\": \"2026-07-30\",\n  \"notes\": \"Direct wholesale customer.\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/customers",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["customers"]
            }
          }
        },
        {
          "name": "Add Follow-Up Note",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Discussed credit limit terms of 30 days. Client agreed to pay 50% advance on next order.\",\n  \"followUpDate\": \"2026-08-05\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/customers/CUSTOMER_ID_HERE/notes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["customers", "CUSTOMER_ID_HERE", "notes"]
            }
          }
        }
      ]
    },
    {
      "name": "Products & Inventory",
      "item": [
        {
          "name": "Get Products (With Low Stock Filter)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/products?lowStock=true",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["products"],
              "query": [
                { "key": "lowStock", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fiber Optic Patch Cord 5m\",\n  \"sku\": \"FBR-PC-5M\",\n  \"category\": \"Cabling\",\n  \"unitPrice\": 850,\n  \"currentStock\": 60,\n  \"minStockAlert\": 15,\n  \"location\": \"Rack E-04\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["products"]
            }
          }
        },
        {
          "name": "Adjust Stock (Stock IN/OUT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 25,\n  \"movementType\": \"IN\",\n  \"reason\": \"Vendor Delivery PO-8810 Received\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/products/PRODUCT_ID_HERE/adjust-stock",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["products", "PRODUCT_ID_HERE", "adjust-stock"]
            }
          }
        }
      ]
    },
    {
      "name": "Sales Challans",
      "item": [
        {
          "name": "Create Confirmed Sales Challan (Validates Stock)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUSTOMER_ID_HERE\",\n  \"status\": \"CONFIRMED\",\n  \"items\": [\n    {\n      \"productId\": \"PRODUCT_ID_HERE\",\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/challans",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["challans"]
            }
          }
        },
        {
          "name": "Get All Challans",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/challans",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["challans"]
            }
          }
        }
      ]
    }
  ]
}
